{
  "serverInfo": {
    "name": "DaoRoute",
    "version": "0.1.0"
  },
  "authentication": {
    "required": true,
    "schemes": ["api-key"]
  },
  "tools": [
    {
      "name": "get_market_snapshot",
      "description": "Return aggregate DaoRoute market coverage, candidate pool intelligence, protocol/chain breakdowns, data-depth evidence, and suggested follow-up actions.",
      "annotations": {
        "readOnlyHint": true,
        "idempotentHint": true,
        "destructiveHint": false
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "asset": {
            "type": "string",
            "default": "USDC"
          },
          "chain": {
            "type": "string",
            "default": "auto"
          },
          "risk_profile": {
            "type": "string",
            "enum": ["conservative", "balanced", "moderate", "aggressive"],
            "default": "conservative"
          },
          "min_pool_tvl_usd": {
            "type": "number",
            "default": 20000000
          },
          "stablecoin_only": {
            "type": "boolean",
            "default": false
          },
          "max_pools": {
            "type": "integer",
            "default": 10
          },
          "verbosity": {
            "type": "string",
            "enum": ["full", "compact"],
            "default": "full",
            "description": "Use compact for agent loops and marketplace demos; use full for pilot review."
          }
        }
      }
    },
    {
      "name": "get_pool_evidence",
      "description": "Return detailed read-only evidence for a pool lookup, including metadata, APY history statistics, TVL context, risk fields, and recommended follow-up actions.",
      "annotations": {
        "readOnlyHint": true,
        "idempotentHint": true,
        "destructiveHint": false
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "pool_id": {
            "type": "integer"
          },
          "protocol": {
            "type": "string"
          },
          "chain": {
            "type": "string"
          },
          "token_symbol": {
            "type": "string"
          },
          "history_days": {
            "type": "integer",
            "default": 365
          },
          "verbosity": {
            "type": "string",
            "enum": ["full", "compact"],
            "default": "full",
            "description": "Use compact for agent loops and marketplace demos; use full for pilot review."
          }
        }
      }
    },
    {
      "name": "get_optimal_allocation",
      "description": "Return a non-custodial stablecoin allocation decision with risk diagnostics, evidence snapshot, execution metadata, and optional signed attestation.",
      "annotations": {
        "readOnlyHint": true,
        "idempotentHint": true,
        "destructiveHint": false
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "capital_amount": {
            "type": "string",
            "description": "Decimal capital amount greater than 0."
          },
          "asset": {
            "type": "string",
            "description": "Starting asset, for example USDC."
          },
          "chain": {
            "type": "string",
            "description": "Target chain or auto."
          },
          "risk_profile": {
            "type": "string",
            "enum": ["conservative", "balanced", "moderate", "aggressive"]
          },
          "signer_address": {
            "type": "string",
            "description": "0x-prefixed EVM signer address. DaoRoute does not custody or sign."
          },
          "attestation_required": {
            "type": "boolean",
            "default": true
          },
          "verbosity": {
            "type": "string",
            "enum": ["full", "compact"],
            "default": "full",
            "description": "Use compact for agent loops and marketplace demos; use full for pilot review."
          }
        },
        "required": [
          "capital_amount",
          "asset",
          "chain",
          "risk_profile",
          "signer_address"
        ]
      }
    },
    {
      "name": "get_protocol_security_status",
      "description": "Return live protocol security status, recommended action, active alerts, and attestation metadata.",
      "annotations": {
        "readOnlyHint": true,
        "idempotentHint": true,
        "destructiveHint": false
      },
      "inputSchema": {
        "type": "object",
        "properties": {
          "protocol": {
            "type": "string",
            "description": "Protocol name, for example aave, compound, or curve."
          },
          "verbosity": {
            "type": "string",
            "enum": ["full", "compact"],
            "default": "full",
            "description": "Use compact for agent loops and marketplace demos; use full for pilot review."
          }
        },
        "required": ["protocol"]
      }
    }
  ],
  "resources": [],
  "prompts": []
}
